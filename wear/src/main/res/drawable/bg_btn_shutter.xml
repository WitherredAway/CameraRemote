<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ripple_dark">
    <item>
        <layer-list>
            <!-- Outer dark ring -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="#FF555555" />
                </shape>
            </item>
            <!-- Inner white circle (inset creates the ring effect) -->
            <item
                android:bottom="5dp"
                android:left="5dp"
                android:right="5dp"
                android:top="5dp">
                <shape android:shape="oval">
                    <solid android:color="#FFFFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
