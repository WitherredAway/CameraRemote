<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:boxedEdges="all">

        <!-- Connection status pill at top -->
        <TextView
            android:id="@+id/tvConnection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_status_active"
            android:drawablePadding="6dp"
            android:text="Checking..."
            android:textSize="10sp"
            android:textColor="@color/on_surface"
            android:gravity="center" />

        <!-- Status text below connection pill -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="24dp"
            android:text="Ready"
            android:textSize="9sp"
            android:textColor="@color/outline"
            android:gravity="center" />

        <!-- Timer (red) at left middle — 9 o'clock -->
        <ImageButton
            android:id="@+id/btnTimer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:translationX="-52dp"
            android:translationY="0dp"
            android:background="@drawable/bg_btn_timer"
            android:src="@drawable/ic_timer"
            android:tint="@android:color/white"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="3s Timer" />

        <!-- Flash (yellow) at bottom-left — 7:30 o'clock -->
        <ImageButton
            android:id="@+id/btnFlash"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:translationX="-37dp"
            android:translationY="37dp"
            android:background="@drawable/bg_btn_flash"
            android:src="@drawable/ic_flash"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Toggle Flash" />

        <!-- Flip (white) at bottom middle — 6 o'clock -->
        <ImageButton
            android:id="@+id/btnSwitch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:translationX="0dp"
            android:translationY="52dp"
            android:background="@drawable/bg_btn_switch"
            android:src="@drawable/ic_flip_camera"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Switch Camera" />

        <!-- Video (white) at bottom-right — 4:30 o'clock -->
        <ImageButton
            android:id="@+id/btnVideo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:translationX="37dp"
            android:translationY="37dp"
            android:background="@drawable/bg_btn_video"
            android:src="@drawable/ic_videocam"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Video Mode" />

        <!-- Shutter (white, large) at center -->
        <ImageButton
            android:id="@+id/btnCapture"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_btn_shutter"
            android:src="@drawable/ic_photo_camera"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="16dp"
            android:contentDescription="Take Photo" />

    </FrameLayout>
</androidx.wear.widget.BoxInsetLayout>
