<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

        <!-- Connection status pill at top -->
        <TextView
            android:id="@+id/tvConnection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_status_active"
            android:drawablePadding="6dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="3dp"
            android:text="Checking..."
            android:textColor="#E6E1E5"
            android:textSize="10sp" />

        <!-- Status text below connection pill -->

        <!-- Camera/Photo (light blue) at 9 o'clock — left middle -->

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="150dp"
            android:layout_height="55dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="Ready"
            android:textColor="#938F99"
            android:textSize="20sp" />

        <ImageButton
            android:id="@+id/btnOpenCamera"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_gravity="center"
            android:translationX="-70dp"
            android:translationY="0dp"
            android:background="@drawable/bg_btn_camera"
            android:src="@drawable/ic_camera"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:contentDescription="Open Camera" />

        <!-- Flash (pastel yellow) at ~7:30 o'clock — bottom-left -->
        <ImageButton
            android:id="@+id/btnFlash"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:translationX="49.5dp"
            android:translationY="49.5dp"
            android:background="@drawable/bg_btn_flash"
            android:src="@drawable/ic_flash"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:contentDescription="Toggle Flash" />

        <!-- Flip (grey) at 6 o'clock — bottom middle -->

        <!-- Video (pastel purple) at ~4:30 o'clock — bottom-right -->

        <ImageButton
            android:id="@+id/btnSwitch"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_btn_switch"
            android:src="@drawable/ic_flip_camera"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:contentDescription="Switch Camera"
            android:translationX="0dp"
            android:translationY="70dp" />

        <!-- Preview (blue-grey) at ~8 o'clock — between timer and camera -->
        <ImageButton
            android:id="@+id/btnPreview"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:translationX="-65dp"
            android:translationY="37dp"
            android:background="@drawable/bg_btn_preview"
            android:src="@drawable/ic_preview"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="5dp"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:contentDescription="Preview" />

        <!-- Burst Timer (pastel orange) at ~4 o'clock — between flash and video -->
        <ImageButton
            android:id="@+id/btnBurstTimer"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:translationX="65dp"
            android:translationY="37dp"
            android:background="@drawable/bg_btn_burst"
            android:src="@drawable/ic_burst"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="5dp"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:contentDescription="Burst Timer" />

        <ImageButton
            android:id="@+id/btnVideo"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_gravity="center"
            android:translationX="70dp"
            android:translationY="0dp"
            android:background="@drawable/bg_btn_video"
            android:src="@drawable/ic_videocam"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:contentDescription="Video Mode" />

        <!-- Timer (pastel red) at 3 o'clock — right middle -->

        <!-- Shutter (white, large) at center -->
        <ImageButton
            android:id="@+id/btnTimer"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_btn_timer"
            android:src="@drawable/ic_timer"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:contentDescription="Timer"
            android:translationX="-49.5dp"
            android:translationY="49.5dp" />

        <ImageButton
            android:id="@+id/btnCapture"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_btn_shutter"
            android:scaleType="centerInside"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:contentDescription="Capture" />

        <!-- Preview overlay (hidden by default) -->
        <FrameLayout
            android:id="@+id/previewOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/previewImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginBottom="50dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:scaleType="fitCenter"
                android:contentDescription="Preview photo" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnPreviewDelete"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_btn_timer"
                    android:src="@android:drawable/ic_menu_delete"
                    android:tint="#000000"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:clipToOutline="true"
                    android:outlineProvider="background"
                    android:contentDescription="Delete" />

                <ImageButton
                    android:id="@+id/btnPreviewSave"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_btn_camera"
                    android:src="@android:drawable/ic_menu_save"
                    android:tint="#000000"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:clipToOutline="true"
                    android:outlineProvider="background"
                    android:contentDescription="Save" />

            </LinearLayout>
        </FrameLayout>

</FrameLayout>
