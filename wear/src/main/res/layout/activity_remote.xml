<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

        <!-- Connection status pill at top -->
        <TextView
            android:id="@+id/tvConnection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_status_active"
            android:drawablePadding="6dp"
            android:text="Checking..."
            android:textSize="10sp"
            android:textColor="#E6E1E5"
            android:gravity="center" />

        <!-- Status text below connection pill -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="28dp"
            android:text="Ready"
            android:textSize="9sp"
            android:textColor="#938F99"
            android:gravity="center" />

        <!-- Camera/Photo (light blue) at 9 o'clock — left middle -->
        <ImageButton
            android:id="@+id/btnOpenCamera"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:translationX="-52dp"
            android:translationY="0dp"
            android:background="@drawable/bg_btn_camera"
            android:src="@drawable/ic_camera"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Open Camera" />

        <!-- Flash (pastel yellow) at ~7:30 o'clock — bottom-left -->
        <ImageButton
            android:id="@+id/btnFlash"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:translationX="-37dp"
            android:translationY="37dp"
            android:background="@drawable/bg_btn_flash"
            android:src="@drawable/ic_flash"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Toggle Flash" />

        <!-- Flip (grey) at 6 o'clock — bottom middle -->
        <ImageButton
            android:id="@+id/btnSwitch"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:translationX="0dp"
            android:translationY="52dp"
            android:background="@drawable/bg_btn_switch"
            android:src="@drawable/ic_flip_camera"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Switch Camera" />

        <!-- Video (pastel purple) at ~4:30 o'clock — bottom-right -->
        <ImageButton
            android:id="@+id/btnVideo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:translationX="37dp"
            android:translationY="37dp"
            android:background="@drawable/bg_btn_video"
            android:src="@drawable/ic_videocam"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Video Mode" />

        <!-- Timer (pastel red) at 3 o'clock — right middle -->
        <ImageButton
            android:id="@+id/btnTimer"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:translationX="52dp"
            android:translationY="0dp"
            android:background="@drawable/bg_btn_timer"
            android:src="@drawable/ic_timer"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Timer" />

        <!-- Shutter (white, large) at center -->
        <ImageButton
            android:id="@+id/btnCapture"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_btn_shutter"
            android:src="@drawable/ic_photo_camera"
            android:tint="#000000"
            android:scaleType="centerInside"
            android:padding="14dp"
            android:contentDescription="Capture" />

</FrameLayout>
